{
  "name": "artlava",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next.mjs dev local",
    "build": "npm run build:local",
    "build:local": "node scripts/build-export.mjs local",
    "build:pages": "node scripts/build-export.mjs pages",
    "start": "node scripts/serve-export.mjs --dir .next-local --port 3000",
    "preview:local": "npm run build:local && npm run start",
    "preview:pages": "npm run build:pages && node scripts/serve-export.mjs --dir .next-pages --port 3000 --basePath /artlava",
    "lint": "eslint",
    "figma:fetch": "node scripts/fetch-figma.mjs"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.58.2",
    "sass": "^1.97.3",
    "typescript": "^5"
  }
}
